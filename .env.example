# Base de datos
DATABASE_URL=jdbc:postgresql://localhost:5432/menusdb
DATABASE_USERNAME=menus
DATABASE_PASSWORD=change_me

# JWT (mínimo 64 bytes en base64)
JWT_SECRET=generate_with__openssl_rand_-base64_64

# Cifrado AES-256 para datos personales (pgcrypto)
ENCRYPTION_KEY=generate_with__openssl_rand_-base64_32

# Google OAuth2
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# CORS
CORS_ORIGINS=http://localhost:3000,https://app.apptolast.com
